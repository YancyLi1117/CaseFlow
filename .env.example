# Runtime connection for Prisma Client.
# For Supabase on Vercel, prefer the pooled / transaction URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Direct connection for Prisma CLI commands such as db push / migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

OPENAI_API_KEY=""
WORK_INCOMING_HOPS=3
OPENAI_MODEL="gpt-5"
OPENAI_MAX_OUTPUT_TOKENS=1000
OPENAI_REASONING_EFFORT="low"
OPENAI_BREVITY_PROMPT="Be concise. Prefer bullet points."
